# Backend environment – used by Express only
# Copy to backend/.env (this file is git-ignored)

# Firebase (required for Firestore) – use one of:
# GOOGLE_APPLICATION_CREDENTIALS=your-firebase-adminsdk-*.json   (path relative to project root)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# On Render: run `pnpm run encode:firebase` and set FIREBASE_SERVICE_ACCOUNT_BASE64 to the output.

# Admin login
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!

# CORS: frontend origin (e.g. https://ksohtc.netlify.app or http://localhost:8080)
# FRONTEND_URL=https://ksohtc.netlify.app

# Server
# PORT=8085

# Deploy (e.g. Render)
# API_ONLY=true
# RENDER=true
