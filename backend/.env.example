# Backend environment – used by Express only
# Copy to backend/.env (this file is git-ignored)

# Firebase (required for Firestore)
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/firebase-admin.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Admin login
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!

# CORS: frontend origin (e.g. https://ksohtc.netlify.app or http://localhost:8080)
# FRONTEND_URL=https://ksohtc.netlify.app

# Server
# PORT=8085

# Deploy (e.g. Render)
# API_ONLY=true
# RENDER=true
