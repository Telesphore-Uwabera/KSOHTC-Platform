# Backend environment – used by Express only
# Copy to backend/.env (this file is git-ignored)

# Firebase (required for Firestore) – use one of:
# GOOGLE_APPLICATION_CREDENTIALS=your-firebase-adminsdk-*.json   (path relative to project root)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# On Render: run `pnpm run encode:firebase` and set FIREBASE_SERVICE_ACCOUNT_BASE64 to the output.

# Admin login
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!

# Optional: secret required to run "Seed courses" from Admin UI (POST /api/admin/seed-courses). If set, the admin must enter this value when clicking "Run seed".
# ADMIN_SEED_SECRET=your-secret-here

# CORS: frontend origin (e.g. https://ksohtc.netlify.app or http://localhost:8080)
# FRONTEND_URL=https://ksohtc.netlify.app

# Server
# PORT=8085

# Deploy (e.g. Render)
# API_ONLY=true
# RENDER=true

# Admin email notifications (optional): when someone registers or submits contact, admin receives an email.
# Registration email includes: name, email, phone, organization, sector.
# Contact email includes: name, email, phone, and message. Uses SMTP. If not set, Firestore still saves; only email is skipped.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# SMTP_FROM=KSOHTC <your-email@gmail.com>

# Optional: Netlify form detection. Backend POSTs to this URL so submissions appear in Netlify Forms (default: FRONTEND_URL).
# NETLIFY_FORM_SUBMIT_URL=https://ksohtc.netlify.app
