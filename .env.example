# Example environment file (safe to commit)

# Backend credentials (choose one approach)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-admin.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Admin login
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!

# If running backend in a separate terminal (optional):
# VITE_DEV_USE_PROXY=true
# BACKEND_URL=http://localhost:8085
# FRONTEND_URL=http://localhost:8080

# When frontend is on Netlify and backend on Render, set in Netlify build env:
# VITE_API_URL=https://your-app.onrender.com

# Public variables
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"
# Optional: API
# PING_MESSAGE=ping

# Firebase Firestore (required for users, testimonials, quizzes)
# Option 1: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json

# Option 2: JSON content in env (e.g. for serverless)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
