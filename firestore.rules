rules_version = '2';

// Firestore is accessed only by the backend (Firebase Admin SDK). Admin SDK bypasses these rules.
// These rules deny all direct client access so only your API can read/write.
// Collections: users, testimonials, quizzes, courses (with modules/lessons/assessments),
// enrollments, submissions, progress, inquiries (contact form).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if false;
    }
    match /testimonials/{docId} {
      allow read, write: if false;
    }
    match /quizzes/{quizId} {
      allow read, write: if false;
    }
    match /courses/{courseId} {
      allow read, write: if false;
      match /modules/{moduleId} {
        allow read, write: if false;
        match /lessons/{lessonId} {
          allow read, write: if false;
        }
        match /assessments/{assessmentId} {
          allow read, write: if false;
        }
      }
    }
    match /enrollments/{docId} {
      allow read, write: if false;
    }
    match /submissions/{docId} {
      allow read, write: if false;
    }
    match /progress/{docId} {
      allow read, write: if false;
    }
    match /inquiries/{docId} {
      allow read, write: if false;
    }
    // Deny any other collection not explicitly listed above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
