# Frontend environment – used by Vite only (VITE_* are exposed to the client)
# Copy to clients/.env (this file is git-ignored). Vite loads from clients/ directory.
# On Netlify, set these in Site settings → Environment variables and redeploy.

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Backend API base URL. Leave empty for local dev (same origin, e.g. /api).
# For production (e.g. frontend on Netlify, backend on Render): set to backend URL with no trailing slash.
# Example: https://ksohtc-api.onrender.com
VITE_API_URL=

# -----------------------------------------------------------------------------
# Public / optional
# -----------------------------------------------------------------------------
# Builder.io public key (if using Builder)
VITE_PUBLIC_BUILDER_KEY=

# App branding (optional – use in index.html meta, footer, etc.)
# VITE_APP_TITLE=Kigali Safety OSH Training Center
# VITE_APP_SHORT_TITLE=KSOHTC
# VITE_SITE_URL=https://ksohtc.netlify.app
# VITE_CONTACT_EMAIL=kigalisafetyoshtrainingcenter@gmail.com

# Feature flags or environment label (optional)
# VITE_ENV=production
# VITE_SHOW_DEBUG=false
